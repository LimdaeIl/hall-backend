      if (response.body.data.status != null) {
        client.assert(
            response.body.data.status === "OPEN",
            "콘서트 상태가 OPEN이 아닙니다."
        );
      }
    }
  });
%}


##################################################
### 6. 공연 회차 생성
##################################################
###
### 현재 좌석 마스터에 VIP, R 외 등급이 존재하고
### 모든 좌석 마스터를 공연 좌석으로 복사하는 구조라면
### 해당 등급 가격도 seatPrices에 추가해야 합니다.

# @name createPerformance
POST {{baseUrl}}/api/v1/admin/performances/create
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "concertId": {{concertId}},
  "startsAt": "{{startsAt}}",
  "reservationOpensAt": "{{reservationOpensAt}}",
  "reservationClosesAt": "{{reservationClosesAt}}",
  "maxTicketsPerMember": 4,
  "seatPrices": [
    {
      "grade": "VIP",
      "price": 150000
    },
    {
      "grade": "R",
      "price": 120000
    }
  ]
}

> {%
