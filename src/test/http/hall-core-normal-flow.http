### HALL 핵심 정상 흐름 통합 테스트
### IntelliJ IDEA HTTP Client용
###
### 실행 방법
### 1. 애플리케이션을 http://localhost:8080에서 실행합니다.
### 2. 전체 요청을 위에서 아래 순서대로 실행합니다.
### 3. 동일 DB에서 재실행할 경우 runId, phoneSuffix, seatRow 값을 변경합니다.
###
### 주의
### - 관리자 권한 변경 API는 테스트 부트스트랩을 위해 인증 없이 호출 가능해야 합니다.
### - 운영 환경에서는 관리자 권한 변경 API를 permitAll로 열어두면 안 됩니다.
### - 응답 DTO 필드명이 코드와 다르면 response.body.data 필드명을 실제 DTO에 맞게 수정해야 합니다.
### - 날짜는 반드시 다음 조건을 만족해야 합니다.
###   reservationOpensAt < 현재 시각 < reservationClosesAt < startsAt


@baseUrl = http://localhost:8080

### 재실행 시 변경
@runId = 260714
@phoneSuffix = 0002
@seatRow = 102

### 관리자 계정
@adminEmail = admin{{runId}}@test.com
@adminPassword = test1234!
@adminName = admin{{runId}}
@adminPhone = 0101234{{phoneSuffix}}

### 일반 회원 계정
@memberEmail = member{{runId}}@test.com
@memberPassword = member1234!
@memberName = member{{runId}}
@memberPhone = 0105678{{phoneSuffix}}

### 테스트용 공연 시간
### 서버 DTO가 LocalDateTime인 경우 아래 형식 사용
@startsAt = 2026-08-01T20:00:00
@reservationOpensAt = 2026-07-01T10:00:00
@reservationClosesAt = 2026-08-01T18:00:00


##################################################
### 0. 관리자 회원가입
##################################################

# @name adminSignUp
POST {{baseUrl}}/api/v1/members/sign-up
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}",
  "name": "{{adminName}}",
  "phone": "{{adminPhone}}"
}

> {%
  client.test("관리자 회원가입 성공", function () {
    client.assert(
        response.status === 201,
        "관리자 회원가입 HTTP 상태가 201이 아닙니다. actual=" + response.status
    );

    client.assert(
        response.body != null,
        "응답 본문이 없습니다."
    );

    client.assert(
        response.body.data != null,
        "응답 data가 없습니다."
    );

    client.assert(
        response.body.data.id != null,
        "관리자 회원 ID가 없습니다. SignUpResponse 필드가 id인지 확인하세요."
    );
  });

  client.global.set("adminId", response.body.data.id);
%}


##################################################
### 0.1 관리자 권한 부여
##################################################

# @name grantAdminRole
PATCH {{baseUrl}}/api/v1/admin/members/{{adminId}}/role
Content-Type: application/json

> {%
  client.test("관리자 권한 부여 성공", function () {
    client.assert(
        response.status === 200 || response.status === 204,
        "관리자 권한 부여에 실패했습니다. actual=" + response.status
    );
  });
%}


