  client.log("concertId         = " + client.global.get("concertId"));
  client.log("performanceId     = " + client.global.get("performanceId"));
  client.log("performanceSeatId1= " + client.global.get("performanceSeatId1"));
  client.log("performanceSeatId2= " + client.global.get("performanceSeatId2"));
  client.log("reservationId     = " + client.global.get("reservationId"));
  client.log("paymentId         = " + client.global.get("paymentId"));
  client.log("transactionKey    = " + client.global.get("transactionKey"));
  client.log("======================================");
%}
