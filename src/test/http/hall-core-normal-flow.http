##################################################
### 12. 예약 가능한 공연 좌석 조회
##################################################

# @name getAvailableSeats
GET {{baseUrl}}/api/v1/performances/{{performanceId}}/seats
Authorization: Bearer {{memberAccessToken}}

> {%
  client.test("예약 가능한 공연 좌석 조회 성공", function () {
    client.assert(
        response.status === 200,
        "공연 좌석 조회 HTTP 상태가 200이 아닙니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "공연 좌석 조회 응답 data가 없습니다."
    );

    client.assert(
        Array.isArray(response.body.data.seats),
        "공연 좌석 응답의 seats가 배열이 아닙니다."
    );

    client.assert(
        response.body.data.seats.length >= 2,
        "예약 가능한 좌석이 2개 미만입니다."
    );
  });

  const seats = response.body.data.seats;

  const firstSeat = seats.find(function (seat) {
    return seat.seatNumber === "VIP-{{runId}}-1";
  });

  const secondSeat = seats.find(function (seat) {
    return seat.seatNumber === "VIP-{{runId}}-2";
  });

  client.test("이번 테스트에서 생성한 VIP 좌석 조회 성공", function () {
    client.assert(
        firstSeat != null,
        "VIP-{{runId}}-1 좌석을 찾을 수 없습니다."
    );

    client.assert(
        secondSeat != null,
        "VIP-{{runId}}-2 좌석을 찾을 수 없습니다."
    );
  });

  client.global.set(
      "performanceSeatId1",
      firstSeat.performanceSeatId
  );

  client.global.set(
      "performanceSeatId2",
      secondSeat.performanceSeatId
  );
%}


##################################################
### 13. 공연 예약 생성
##################################################
###
### 기대 상태
### Reservation: PENDING_PAYMENT
### PerformanceSeat: AVAILABLE -> HELD

# @name createReservation
POST {{baseUrl}}/api/v1/performances/{{performanceId}}/reservations
Authorization: Bearer {{memberAccessToken}}
Content-Type: application/json

{
  "performanceSeatIds": [
    {{performanceSeatId1}},
    {{performanceSeatId2}}
  ]
}

> {%
  client.test("공연 예약 생성 성공", function () {
    client.assert(
        response.status === 200 || response.status === 201,
        "예약 생성에 실패했습니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "예약 생성 응답 data가 없습니다."
    );

    client.assert(
        response.body.data.reservationId != null,
        "reservationId가 없습니다."
    );

    if (response.body.data.status != null) {
      client.assert(
          response.body.data.status === "PENDING_PAYMENT",
          "예약 상태가 PENDING_PAYMENT가 아닙니다."
      );
    }
  });

  client.global.set(
      "reservationId",
      response.body.data.reservationId
  );
%}


##################################################
### 14. 예약 직후 가용 좌석 재조회
##################################################
###
### 예약한 좌석은 HELD 상태이므로
### AVAILABLE 목록에서 제외되어야 합니다.

# @name getAvailableSeatsAfterReservation
GET {{baseUrl}}/api/v1/performances/{{performanceId}}/seats
Authorization: Bearer {{memberAccessToken}}

> {%
  client.test("예약 좌석이 AVAILABLE 목록에서 제외됨", function () {
    client.assert(
        response.status === 200,
        "예약 후 좌석 조회 HTTP 상태가 200이 아닙니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "예약 후 좌석 조회 응답 data가 없습니다."
    );

    client.assert(
        Array.isArray(response.body.data.seats),
        "예약 후 좌석 응답의 seats가 배열이 아닙니다."
    );

    const firstReservedId =
        Number(client.global.get("performanceSeatId1"));

    const secondReservedId =
        Number(client.global.get("performanceSeatId2"));

    const stillAvailable = response.body.data.seats.some(function (seat) {
      const currentSeatId = Number(seat.performanceSeatId);

      return currentSeatId === firstReservedId
          || currentSeatId === secondReservedId;
    });

    client.assert(
        !stillAvailable,
        "HELD 좌석이 AVAILABLE 목록에 남아 있습니다."
    );
  });
%}


##################################################
### 15. MOCK 결제
##################################################
###
### 기대 상태
### Payment: COMPLETED
### Reservation: PENDING_PAYMENT -> COMPLETED
### PerformanceSeat: HELD -> RESERVED

# @name createPayment
POST {{baseUrl}}/api/v1/reservations/{{reservationId}}/payments
Authorization: Bearer {{memberAccessToken}}
Content-Type: application/json

{
  "method": "MOCK"
}

> {%
  client.test("MOCK 결제 성공", function () {
    client.assert(
        response.status === 200 || response.status === 201,
        "결제 생성에 실패했습니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "결제 응답 data가 없습니다."
    );

    client.assert(
        response.body.data.paymentId != null,
        "paymentId가 없습니다."
    );

    client.assert(
        response.body.data.transactionKey != null,
        "transactionKey가 없습니다."
    );

    if (response.body.data.status != null) {
      client.assert(
          response.body.data.status === "COMPLETED",
          "결제 상태가 COMPLETED가 아닙니다."
      );
    }
  });

  client.global.set(
      "paymentId",
      response.body.data.paymentId
  );

  client.global.set(
      "transactionKey",
      response.body.data.transactionKey
  );
%}


##################################################
### 16. 동일 결제 재호출
##################################################
###
### 멱등성 기대 결과
### - 새로운 Payment가 생성되지 않아야 합니다.
### - 기존 paymentId를 반환해야 합니다.
### - 기존 transactionKey를 반환해야 합니다.
###
### 현재 컨트롤러가 기존 결제를 반환해도 201을 반환하는 경우
### 아래 상태 코드 검증은 200 또는 201 모두 허용합니다.

# @name retryPayment
POST {{baseUrl}}/api/v1/reservations/{{reservationId}}/payments
Authorization: Bearer {{memberAccessToken}}
Content-Type: application/json

{
  "method": "MOCK"
}

> {%
  client.test("동일 결제 재호출 멱등성 성공", function () {
    client.assert(
        response.status === 200 || response.status === 201,
        "동일 결제 재호출에 실패했습니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "결제 재호출 응답 data가 없습니다."
    );

    client.assert(
        Number(response.body.data.paymentId)
        === Number(client.global.get("paymentId")),
        "결제 재호출 시 새로운 paymentId가 반환되었습니다."
    );

    client.assert(
        response.body.data.transactionKey
        === client.global.get("transactionKey"),
        "결제 재호출 시 transactionKey가 달라졌습니다."
    );
  });
%}


##################################################
### 17. 결제 후 가용 좌석 최종 조회
##################################################
###
### 결제된 좌석은 RESERVED 상태이므로
### AVAILABLE 목록에 나타나지 않아야 합니다.

# @name getAvailableSeatsAfterPayment
GET {{baseUrl}}/api/v1/performances/{{performanceId}}/seats
Authorization: Bearer {{memberAccessToken}}

> {%
  client.test("결제된 좌석이 AVAILABLE 목록에서 제외됨", function () {
    client.assert(
        response.status === 200,
        "결제 후 좌석 조회 HTTP 상태가 200이 아닙니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "결제 후 좌석 조회 응답 data가 없습니다."
    );

    client.assert(
        Array.isArray(response.body.data.seats),
        "결제 후 좌석 응답의 seats가 배열이 아닙니다."
    );

    const firstReservedId =
        Number(client.global.get("performanceSeatId1"));

    const secondReservedId =
        Number(client.global.get("performanceSeatId2"));

    const stillAvailable = response.body.data.seats.some(function (seat) {
      const currentSeatId = Number(seat.performanceSeatId);

      return currentSeatId === firstReservedId
          || currentSeatId === secondReservedId;
    });

    client.assert(
        !stillAvailable,
        "RESERVED 좌석이 AVAILABLE 목록에 남아 있습니다."
    );
  });
%}


