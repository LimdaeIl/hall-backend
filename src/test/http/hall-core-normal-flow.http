    client.assert(
        response.body != null && response.body.data != null,
        "공연 회차 생성 응답 data가 없습니다."
    );

    client.assert(
        response.body.data.performanceId != null,
        "performanceId가 없습니다."
    );
  });

  client.global.set(
      "performanceId",
      response.body.data.performanceId
  );
%}


