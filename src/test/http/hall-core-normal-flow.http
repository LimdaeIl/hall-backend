    );

    client.assert(
        response.body != null && response.body.data != null,
        "관리자 로그인 응답 data가 없습니다."
    );

    client.assert(
        response.body.data.accessToken != null,
        "관리자 accessToken이 없습니다."
    );
  });

  client.global.set(
      "adminAccessToken",
      response.body.data.accessToken
  );
%}


##################################################
### 2. 좌석 마스터 생성
##################################################

# @name createSeats
POST {{baseUrl}}/api/v1/admin/seats/create
Authorization: Bearer {{adminAccessToken}}
Content-Type: application/json

{
  "seats": [
    {
      "seatNumber": "VIP-{{runId}}-1",
      "rowNumber": {{seatRow}},
      "columnNumber": 1,
      "grade": "VIP"
    },
    {
      "seatNumber": "VIP-{{runId}}-2",
      "rowNumber": {{seatRow}},
      "columnNumber": 2,
      "grade": "VIP"
    },
    {
      "seatNumber": "R-{{runId}}-1",
      "rowNumber": {{seatRow}},
      "columnNumber": 3,
      "grade": "R"
    },
    {
      "seatNumber": "R-{{runId}}-2",
      "rowNumber": {{seatRow}},
      "columnNumber": 4,
      "grade": "R"
    }
  ]
}

> {%
  client.test("좌석 마스터 생성 성공", function () {
    client.assert(
        response.status === 200 || response.status === 201,
        "좌석 생성에 실패했습니다. actual=" + response.status
    );

    client.assert(
        response.body != null && response.body.data != null,
        "좌석 생성 응답 data가 없습니다."
    );

    client.assert(
        Array.isArray(response.body.data.seats),
        "좌석 생성 응답의 seats가 배열이 아닙니다."
    );

    client.assert(
        response.body.data.seats.length === 4,
        "생성된 좌석 수가 4개가 아닙니다."
    );
  });

  client.global.set(
      "masterSeatId1",
      response.body.data.seats[0].id
  );

  client.global.set(
      "masterSeatId2",
      response.body.data.seats[1].id
  );
%}


