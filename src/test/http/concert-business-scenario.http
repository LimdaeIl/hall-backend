Authorization: Bearer {{adminAccessToken}}
Content-Type: {{contentType}}

{
  "title": "2026 HTTP Scenario Concert - Updated",
  "artist": "Scenario Band",
  "description": "생성 및 수정 로직이 검증된 콘서트"
}

> {%
  client.test("콘서트 수정 성공", function () {
    client.assert(response.status === 200, "HTTP 200이 아닙니다.");
    client.assert(response.body.data.title.includes("Updated"), "수정된 제목이 반영되지 않았습니다.");
  });
%}


