### 16. 예약 가능 좌석 조회 및 예약용 좌석 ID 추출
### 기대 결과: 최소 3개 이상의 AVAILABLE 좌석 조회
# @name getAvailableSeats
GET {{baseUrl}}/api/v1/performances/{{performanceId}}/seats

> {%
  const body = response.body;
  const data = body && body.data;
  const seats = data && data.seats;

  client.test("예약 가능 좌석 조회 성공", function () {
    client.assert(response.status === 200,
        "좌석 조회 실패: HTTP " + response.status +
        " / body=" + JSON.stringify(body)
    );

    client.assert(Array.isArray(seats),
        "data.seats가 배열이 아닙니다: " + JSON.stringify(data)
    );

    client.assert(seats.length >= 3,
        "예약/취소 시나리오에 필요한 좌석이 부족합니다: " +
        JSON.stringify(seats)
    );

    client.assert(seats[0].performanceSeatId != null,
        "첫 번째 좌석에 performanceSeatId가 없습니다: " +
        JSON.stringify(seats[0])
    );

    client.assert(seats[1].performanceSeatId != null,
        "두 번째 좌석에 performanceSeatId가 없습니다: " +
        JSON.stringify(seats[1])
    );
  });

  if (Array.isArray(seats) && seats.length >= 3) {
    client.log("선택된 결제 좌석 1: " + JSON.stringify(seats[0]));
    client.log("선택된 결제 좌석 2: " + JSON.stringify(seats[1]));
    client.log("선택된 취소 좌석: " + JSON.stringify(seats[2]));

    client.global.set("paymentSeatId1", seats[0].performanceSeatId);
    client.global.set("paymentSeatId2", seats[1].performanceSeatId);
    client.global.set("cancelSeatId", seats[2].performanceSeatId);
  }
%}


### 17. 결제할 예약 생성: 좌석 2매
# @name createPaymentReservation
POST {{baseUrl}}/api/v1/performances/{{performanceId}}/reservations
Authorization: Bearer {{memberAccessToken}}
Content-Type: {{contentType}}

{
  "performanceSeatIds": [
    {{paymentSeatId1}},
    {{paymentSeatId2}}
  ]
}

> {%
  const body = response.body;
  const data = body && body.data;

  client.test("결제 대상 예약 생성 성공", function () {
    client.assert(
        response.status === 201,
        "예약 생성 실패: HTTP " + response.status +
        " / body=" + JSON.stringify(body)
    );

    client.assert(
        data && data.reservationId != null,
        "reservationId가 없습니다: " + JSON.stringify(data)
    );

    client.assert(
        data.status === "PENDING_PAYMENT",
        "예약 상태가 PENDING_PAYMENT가 아닙니다."
    );

    client.assert(
        data && Array.isArray(data.seats) && data.seats.length === 2,
        "예약 좌석 수가 2개가 아닙니다."
    );
  });

  if (data && data.reservationId != null) {
    client.global.set("paymentReservationId", data.reservationId);
  }
%}



### 18. 예약 직후 좌석 상태 검증
### 기대 결과: 선택한 좌석이 AVAILABLE 목록에서 제외되거나 HELD 처리됨
GET {{baseUrl}}/api/v1/performances/{{performanceId}}/seats

> {%
  const ids = response.body.data.seats.map(s => String(s.performanceSeatId));
  client.test("예약 좌석이 공개 AVAILABLE 목록에서 제외됨", function () {
    client.assert(!ids.includes(String(client.global.get("paymentSeatId1"))), "첫 번째 예약 좌석이 여전히 AVAILABLE입니다.");
    client.assert(!ids.includes(String(client.global.get("paymentSeatId2"))), "두 번째 예약 좌석이 여전히 AVAILABLE입니다.");
  });
%}


