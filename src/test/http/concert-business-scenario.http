@baseUrl = http://localhost:8080
@contentType = application/json

### 사전에 존재해야 하는 관리자 계정
@adminEmail = admin@example.com
@adminPassword = Admin1234!

### 시나리오에서 신규 생성할 일반 회원
@memberEmail = scenario-user-20260715@example.com
@memberPassword = User1234!
@memberName = 시나리오회원
@memberPhone = 01012345678

### 공연 일정: 실행 시점에 맞게 미래 날짜로 변경
@reservationOpensAt = 2026-07-15T00:00:00
@reservationClosesAt = 2026-08-30T23:59:59
@startsAt = 2026-08-31T19:00:00

### 관리자 회원가입
POST http://localhost:8080/api/v1/members/sign-up
Content-Type: application/json

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}",
  "name": "AdminUser",
  "phone": "01012341234"
}

> {%
   client.global.set("adminId", response.body.data.id);
%}


### 권한 관리자로 수정
PATCH http://localhost:8080/api/v1/admin/members/{{adminId}}/role
Content-Type: application/json

### 관리자 로그인
# @name adminSignIn
POST {{baseUrl}}/api/v1/auth/sign-in
Content-Type: {{contentType}}

{
  "email": "{{adminEmail}}",
  "password": "{{adminPassword}}"
}

> {%
client.test("관리자 로그인 성공", function () {
  client.assert(response.status === 200, "HTTP 200이 아닙니다.");
  client.assert(response.body.data.accessToken, "Access Token이 없습니다.");
});
client.global.set("adminAccessToken", response.body.data.accessToken);
client.global.set("adminMemberId", response.body.data.memberId);
if (response.body.data.refreshToken) {
  client.global.set("adminRefreshToken", response.body.data.refreshToken);
}
%}


### 1. 공연장 기준 좌석 생성
### 기대 결과: 좌석 4개 생성
# @name createVenueSeats
POST {{baseUrl}}/api/v1/admin/seats
Authorization: Bearer {{adminAccessToken}}
Content-Type: {{contentType}}

{
  "seats": [
    {
      "seatNumber": "A-1",
      "rowNumber": 1,
      "columnNumber": 1,
      "grade": "VIP"
    },
    {
      "seatNumber": "A-2",
      "rowNumber": 1,
      "columnNumber": 2,
      "grade": "VIP"
    },
    {
      "seatNumber": "B-1",
      "rowNumber": 2,
      "columnNumber": 1,
      "grade": "R"
    },
    {
      "seatNumber": "B-2",
      "rowNumber": 2,
      "columnNumber": 2,
      "grade": "R"
    }
  ]
}

> {%
  client.test("공연장 좌석 생성 성공", function () {
    client.assert(response.status === 200, "HTTP 200이 아닙니다.");
    client.assert(response.body.data.createdCount === 4, "생성 좌석 수가 4가 아닙니다.");
  });
%}


